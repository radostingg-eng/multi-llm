#  SELF-UPDATE
# ═════════════════════════════════════════════════════════════════════════════

def self_update():
    script_dir = os.path.dirname(os.path.abspath(__file__))
    print("  Updating multi-llm...")
    ret = subprocess.call(["git", "pull", "origin", "main"], cwd=script_dir)
    if ret == 0:
        print("  Up to date!")
    else:
        print("  Update failed. Check your internet connection.")


# ═════════════════════════════════════════════════════════════════════════════
#  MAIN
# ═════════════════════════════════════════════════════════════════════════════

HELP_TEXT = """
  multi-llm (ml) — Smart Gemini CLI launcher

  ml                      Launch Gemini CLI (next available key)
  ml "question"           Smart route: Groq answers simple Qs instantly,
                          complex ones go to Gemini with enhanced prompt
  ml --status             Show which keys are ready
  ml --add                Add more keys
  ml --update             Pull latest version
  ml --version            Show version
  ml --reset              Clear all cooldowns
  ml --no-enhance         Skip prompt enhancement

  Gemini CLI flags pass through:
    ml -p "explain this"
    ml --model gemini-2.5-pro

  Smart features (powered by Groq):
    - Simple questions answered instantly (saves Gemini quota)
    - Complex prompts rewritten for better results
    - Quick-chat fallback when Gemini keys are exhausted
    - Session summaries for conversation continuity
"""


def main():
    args = sys.argv[1:]

    if args and args[0] in ("--help", "-h"):
        print(HELP_TEXT)
        return

    if args and args[0] in ("--version", "-v"):
        version_file = os.path.join(os.path.dirname(os.path.abspath(__file__)), "VERSION")
        try:
            with open(version_file) as f:
                ver = f.read().strip()
        except FileNotFoundError:
            ver = "unknown"
        print("  multi-llm v%s" % ver)
        return

    if args and args[0] == "--update":
        self_update()
        return

    cfg = load_config()

    if args and args[0] == "--reset":
        if cfg:
            cfg["cooldowns"] = {}
            save_config(cfg)
            print("  Cooldowns cleared.")
        return

    if args and args[0] == "--status":
        print("  " + status_line(cfg) if cfg else "  Not set up. Run 'ml'.")
        return

    if args and args[0] == "--add":
        if not cfg:
            cfg = {"gemini_keys": [], "groq_keys": [], "cooldowns": {}}
        _add_keys_interactive(cfg)
        save_config(cfg)
        return

    # First-time setup
    if cfg is None:
        cfg = setup()

    print("  %s" % status_line(cfg))

    # Check for prompt mode
    no_enhance = "--no-enhance" in args
    args = [a for a in args if a != "--no-enhance"]

    prompt = None
    if args and args[0] == "-p" and len(args) > 1:
        prompt = args[1]
    elif args and not args[0].startswith("-"):
        prompt = " ".join(args)

    # Smart routing for prompt mode
    if prompt:
        route = route_query(cfg, prompt)

        if route == "simple":
            print("  [instant answer via Groq]")
            if groq_answer(cfg, prompt):
                print()
                return

        if not no_enhance:
            enhanced = enhance_prompt(cfg, prompt)
            if enhanced != prompt:
                print("  [enhanced prompt]")
                prompt = enhanced

        args = ["-p", prompt]

    # Load previous summary as context
    summary = load_summary()
    if summary and not args:
        args = ["-i", "Context from your last session: %s" % summary]

    # Try each Gemini key
    for i, key in enumerate(cfg.get("gemini_keys", [])):
        if not is_available(cfg, "gemini", i):
            continue

        print("  Using Gemini key #%d" % (i + 1))
        print()
        exit_code = launch_gemini(key, args)

        if exit_code == 0:
            summarize_session(cfg)
            return

        print()
        print("  Gemini exited (code %d). Marking key #%d as rate-limited." % (exit_code, i + 1))
        mark_limited(cfg, "gemini", i)

        remaining = sum(
            1 for j in range(len(cfg["gemini_keys"]))
            if is_available(cfg, "gemini", j)
        )
        if remaining:
            print("  Trying next key (%d left)..." % remaining)
            continue
        break

    # All Gemini keys exhausted → Groq quick-chat
    groq_key, _ = get_groq_key(cfg)
    if groq_key:
        print()
        print("  All Gemini keys on cooldown.")
        groq_quick_chat(cfg)
    else:
        print("  All keys on cooldown! Try again in ~1h or add more: ml --add")


if __name__ == "__main__":
    main()
