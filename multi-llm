#!/usr/bin/env python3
"""
multi-llm — Smart Gemini CLI launcher with Groq-powered extras.

- Rotates Gemini API keys (launches real Gemini CLI)
- Smart routing: simple questions answered instantly by Groq
- Prompt enhancer: Groq rewrites your prompt before Gemini sees it
- Quick-chat fallback: Groq chat when all Gemini keys are exhausted
- Session memory: summarizes conversations for continuity
"""

import json
import os
import shutil
import subprocess
import sys
import time
import urllib.request
import urllib.error

# ─── paths ───────────────────────────────────────────────────────────────────
CONFIG_DIR = os.path.expanduser("~/.multi-llm")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")
SUMMARY_FILE = os.path.join(CONFIG_DIR, "last_summary.txt")
COOLDOWN_SECS = 3600
SUMMARY_MAX_AGE = 86400  # 24h — old summaries are ignored

# ─── Groq ────────────────────────────────────────────────────────────────────
GROQ_URL = "https://api.groq.com/openai/v1/chat/completions"
GROQ_MODEL = "llama-3.3-70b-versatile"

# ─── Gemini ──────────────────────────────────────────────────────────────────
GEMINI_VALIDATE_URL = "https://generativelanguage.googleapis.com/v1beta/models?key=%s"


# ═════════════════════════════════════════════════════════════════════════════
#  CONFIG
# ═════════════════════════════════════════════════════════════════════════════

def load_config():
    if not os.path.exists(CONFIG_FILE):
        return None
    try:
        with open(CONFIG_FILE) as f:
            cfg = json.load(f)
        # Ensure required fields exist
        cfg.setdefault("gemini_keys", [])
        cfg.setdefault("groq_keys", [])
        cfg.setdefault("cooldowns", {})
        return cfg
    except (json.JSONDecodeError, IOError):
        return None


def save_config(cfg):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)
    _secure_file(CONFIG_FILE)


def _secure_file(path):
    """Set file permissions so only the current user can read it."""
    if os.name == "nt":
        # Windows: use icacls to restrict access
        try:
            username = os.environ.get("USERNAME", "")
            if username:
                subprocess.call(
                    ["icacls", path, "/inheritance:r",
                     "/grant:r", "%s:(R,W)" % username],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                )
        except FileNotFoundError:
            pass  # icacls not available
    else:
        os.chmod(path, 0o600)


# ═════════════════════════════════════════════════════════════════════════════
#  KEY VALIDATION
# ═════════════════════════════════════════════════════════════════════════════

def validate_gemini_key(key):
    """Quick check if a Gemini key works."""
    try:
        req = urllib.request.Request(
            GEMINI_VALIDATE_URL % key,
            headers={"User-Agent": "multi-llm/1.0"},
        )
        urllib.request.urlopen(req, timeout=10)
        return True
    except (urllib.error.HTTPError, urllib.error.URLError, OSError):
        return False


def validate_groq_key(key):
    """Quick check if a Groq key works."""
    try:
        req = urllib.request.Request(
            "https://api.groq.com/openai/v1/models",
            headers={
                "Authorization": "Bearer %s" % key,
                "User-Agent": "multi-llm/1.0",
            },
        )
        urllib.request.urlopen(req, timeout=10)
        return True
    except (urllib.error.HTTPError, urllib.error.URLError, OSError):
        return False


def check_gemini_cli():
    """Check if Gemini CLI is installed."""
    return shutil.which("gemini") is not None


# ═════════════════════════════════════════════════════════════════════════════
#  SETUP
# ═════════════════════════════════════════════════════════════════════════════

def setup():
    print()
    print("  multi-llm — First-Time Setup")
    print()
    print("  This tool rotates your free API keys and launches the")
    print("  real Gemini CLI. Simple questions get answered instantly")
    print("  by Groq to save your Gemini quota.")
    print()

    # Check Gemini CLI
    if not check_gemini_cli():
        print("  WARNING: Gemini CLI not found!")
        print("  Install it: npm install -g @google/gemini-cli")
        print("  (You can still set up keys now and install Gemini CLI later.)")
        print()

    cfg = {"gemini_keys": [], "groq_keys": [], "cooldowns": {}}

    for var in sorted(os.environ.keys()):
        if var.startswith("GEMINI_API_KEY"):
            val = os.environ[var].strip()
            if val:
                cfg["gemini_keys"].append(val)
    for var in sorted(os.environ.keys()):
        if var.startswith("GROQ_API_KEY"):
            val = os.environ[var].strip()
            if val:
                cfg["groq_keys"].append(val)

    found = len(cfg["gemini_keys"]) + len(cfg["groq_keys"])
    if found:
        print("  Found %d Gemini + %d Groq key(s) in your environment." % (
            len(cfg["gemini_keys"]), len(cfg["groq_keys"])))
        print("  Validating keys...")
        _validate_keys(cfg)
    else:
        print("  No keys found. Get free keys:")
        print("    Gemini: https://aistudio.google.com/apikey")
        print("    Groq:   https://console.groq.com/keys")
        print()
        _add_keys_interactive(cfg)

    if not cfg["gemini_keys"] and not cfg["groq_keys"]:
        print("  No keys added.")
        sys.exit(1)

    save_config(cfg)
    print("  Saved %d Gemini + %d Groq key(s)." % (
        len(cfg["gemini_keys"]), len(cfg["groq_keys"])))
    print("  You're ready! Launching now...")
    print()
    return cfg


def _validate_keys(cfg):
    """Test each key and remove bad ones."""
    good_gemini = []
    for i, key in enumerate(cfg["gemini_keys"]):
        if validate_gemini_key(key):
            good_gemini.append(key)
            print("    Gemini key #%d — OK" % (i + 1))
        else:
            print("    Gemini key #%d — INVALID (removed)" % (i + 1))
    cfg["gemini_keys"] = good_gemini

    good_groq = []
    for i, key in enumerate(cfg["groq_keys"]):
        if validate_groq_key(key):
            good_groq.append(key)
            print("    Groq key #%d — OK" % (i + 1))
        else:
            print("    Groq key #%d — INVALID (removed)" % (i + 1))
    cfg["groq_keys"] = good_groq
    print()


def _is_duplicate_key(key, key_list):
    """Check if key already exists in list."""
    return key in key_list


def _add_keys_interactive(cfg):
    print("  Paste keys one at a time. Press Enter when done.")
    print()
    while True:
        print("  [1] Gemini key   [2] Groq key   [enter] Done")
        choice = input("  > ").strip()
        if not choice:
            if not cfg["gemini_keys"] and not cfg["groq_keys"]:
                print("  Need at least one key!")
                continue
            break
        elif choice == "1":
            key = input("  Gemini key: ").strip()
            if key:
                if _is_duplicate_key(key, cfg["gemini_keys"]):
                    print("  That key is already added.")
                elif validate_gemini_key(key):
                    cfg["gemini_keys"].append(key)
                    print("  Gemini key #%d — OK" % len(cfg["gemini_keys"]))
                else:
                    print("  That key didn't work. Check it and try again.")
        elif choice == "2":
            key = input("  Groq key: ").strip()
            if key:
                if _is_duplicate_key(key, cfg["groq_keys"]):
                    print("  That key is already added.")
                elif validate_groq_key(key):
                    cfg["groq_keys"].append(key)
                    print("  Groq key #%d — OK" % len(cfg["groq_keys"]))
                else:
                    print("  That key didn't work. Check it and try again.")
        print()


# ═════════════════════════════════════════════════════════════════════════════
#  COOLDOWNS
# ═════════════════════════════════════════════════════════════════════════════

def is_available(cfg, provider, idx):
    key = "%s:%d" % (provider, idx)
    ts = cfg.get("cooldowns", {}).get(key, 0)
    return time.time() - ts > COOLDOWN_SECS


def mark_limited(cfg, provider, idx):
    cfg.setdefault("cooldowns", {})["%s:%d" % (provider, idx)] = time.time()
    save_config(cfg)


def status_line(cfg):
    g = len(cfg.get("gemini_keys", []))
    g_up = sum(1 for i in range(g) if is_available(cfg, "gemini", i))
    q = len(cfg.get("groq_keys", []))
    q_up = sum(1 for i in range(q) if is_available(cfg, "groq", i))
    parts = []
    if g:
        parts.append("Gemini: %d/%d" % (g_up, g))
    if q:
        parts.append("Groq: %d/%d" % (q_up, q))
    return "  ".join(parts) if parts else "No keys"


def get_groq_key(cfg):
    """Return first available Groq key, or None."""
    for i, key in enumerate(cfg.get("groq_keys", [])):
        if is_available(cfg, "groq", i):
            return key, i
    return None, None


# ═════════════════════════════════════════════════════════════════════════════
#  GROQ API
# ═════════════════════════════════════════════════════════════════════════════

def groq_call(api_key, messages, stream=False):
    """Call Groq API. Returns (text, error_code)."""
    payload = json.dumps({
        "model": GROQ_MODEL,
        "messages": messages,
        "stream": stream,
    }).encode()

    req = urllib.request.Request(GROQ_URL, data=payload, headers={
        "Authorization": "Bearer %s" % api_key,
        "Content-Type": "application/json",
        "User-Agent": "multi-llm/1.0",
    })

    try:
        resp = urllib.request.urlopen(req)
    except urllib.error.HTTPError as e:
        if e.code == 429:
            return None, 429
        return None, e.code
    except urllib.error.URLError:
        return None, -1

    if not stream:
        try:
            data = json.loads(resp.read().decode())
            return data["choices"][0]["message"]["content"], 0
        except (json.JSONDecodeError, KeyError, IndexError):
            return None, -2

    full = []
    for line in resp:
        line = line.decode().strip()
        if not line.startswith("data: "):
            continue
        d = line[6:]
        if d == "[DONE]":
            break
        try:
            c = json.loads(d)["choices"][0].get("delta", {}).get("content", "")
            if c:
                print(c, end="", flush=True)
                full.append(c)
        except (json.JSONDecodeError, KeyError, IndexError):
            continue
    print()
    return "".join(full), 0


# ═════════════════════════════════════════════════════════════════════════════
#  FEATURE 1: SMART ROUTING
# ═════════════════════════════════════════════════════════════════════════════

def route_query(cfg, query):
    """Use Groq to classify: 'simple' or 'complex'."""
    groq_key, _ = get_groq_key(cfg)
    if not groq_key:
        return "complex"

    result, code = groq_call(groq_key, [{
        "role": "user",
        "content": (
            "You are a router. Decide if this question needs file access, "
            "code editing, terminal commands, or browsing (reply COMPLEX), "
            "or if it's a general knowledge/conversational question that can "
            "be answered from memory (reply SIMPLE). Reply with ONLY the word "
            "SIMPLE or COMPLEX.\n\nQuestion: %s" % query
        ),
    }])

    if code != 0 or not result:
        print("  [routing unavailable, using Gemini]")
        return "complex"
    return "simple" if "SIMPLE" in result.upper() else "complex"


def groq_answer(cfg, query):
    """Answer a simple question with Groq (streaming). Returns True if answered."""
    groq_key, idx = get_groq_key(cfg)
    if not groq_key:
        return False

    context = load_summary()
    messages = []
    if context:
        messages.append({
            "role": "system",
            "content": "Previous conversation summary: %s" % context,
        })
    messages.append({"role": "user", "content": query})

    print()
    text, code = groq_call(groq_key, messages, stream=True)

    if code == 429:
        mark_limited(cfg, "groq", idx)
        print("  [Groq rate limited, falling back to Gemini]")
        return False
    if code != 0 or not text:
        print("  [Groq unavailable, falling back to Gemini]")
        return False
    return True


# ═════════════════════════════════════════════════════════════════════════════
#  FEATURE 2: PROMPT ENHANCER
# ═════════════════════════════════════════════════════════════════════════════

def enhance_prompt(cfg, query):
    """Use Groq to rewrite the prompt for better Gemini results."""
    groq_key, _ = get_groq_key(cfg)
    if not groq_key:
        return query

    result, code = groq_call(groq_key, [{
        "role": "user",
        "content": (
            "Rewrite this prompt to be clearer and more specific for an AI "
            "coding assistant. Keep the same intent but make it unambiguous. "
            "Return ONLY the rewritten prompt, nothing else.\n\n"
            "Original: %s" % query
        ),
    }])

    if code == 0 and result and len(result) < len(query) * 5:
        return result.strip()
    if code != 0:
        print("  [enhancement unavailable, using original prompt]")
    return query


# ═════════════════════════════════════════════════════════════════════════════
#  FEATURE 3: GROQ QUICK-CHAT FALLBACK
# ═════════════════════════════════════════════════════════════════════════════

def groq_quick_chat(cfg):
    """Basic Groq chat when all Gemini keys are exhausted."""
    groq_key, groq_idx = get_groq_key(cfg)
    if not groq_key:
        return

    # Calculate when next Gemini key is back
    next_back = None
    for i in range(len(cfg.get("gemini_keys", []))):
        ts = cfg.get("cooldowns", {}).get("gemini:%d" % i, 0)
        if ts > 0:
            back_at = ts + COOLDOWN_SECS
            if next_back is None or back_at < next_back:
                next_back = back_at

    print()
    print("  Quick-chat mode (Groq) — text only, no tools/files")
    if next_back:
        mins_left = max(0, int((next_back - time.time()) / 60))
        print("  Gemini keys available again in ~%dm" % mins_left)
    print("  Type 'quit' to exit")
    print()

    messages = []
    context = load_summary()
    if context:
        messages.append({
            "role": "system",
            "content": "Previous conversation summary: %s" % context,
        })

    while True:
        try:
            user_input = input("> ")
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if user_input.strip().lower() in ("quit", "exit"):
            break
        if not user_input.strip():
            continue

        messages.append({"role": "user", "content": user_input})
        print()

        text, code = groq_call(groq_key, messages, stream=True)
        if code == 429:
            mark_limited(cfg, "groq", groq_idx)
            groq_key, groq_idx = get_groq_key(cfg)
            if groq_key:
                print("  [switched Groq key]")
                text, code = groq_call(groq_key, messages, stream=True)
            else:
                print("  All keys exhausted! Try again in ~1h or add more: ml --add")
                break

        if text:
            messages.append({"role": "assistant", "content": text})
        else:
            messages.pop()
            print("  [no response, try again]")
        print()


# ═════════════════════════════════════════════════════════════════════════════
#  FEATURE 4: SESSION SUMMARY
# ═════════════════════════════════════════════════════════════════════════════

def _gemini_history_dir():
    """Find Gemini CLI history directory (cross-platform)."""
    candidates = [
        os.path.expanduser("~/.gemini/history"),
        os.path.join(os.environ.get("APPDATA", ""), "gemini-cli", "history"),
        os.path.join(os.environ.get("LOCALAPPDATA", ""), "gemini-cli", "history"),
    ]
    for d in candidates:
        if d and os.path.isdir(d):
            return d
    return None


def load_summary():
    """Load last session summary if it exists and isn't too old."""
    if not os.path.exists(SUMMARY_FILE):
        return None
    # Check age — ignore stale summaries
    age = time.time() - os.path.getmtime(SUMMARY_FILE)
    if age > SUMMARY_MAX_AGE:
        return None
    try:
        with open(SUMMARY_FILE) as f:
            return f.read().strip()
    except IOError:
        return None


def save_summary(text):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(SUMMARY_FILE, "w") as f:
        f.write(text)


def summarize_session(cfg):
    """After Gemini exits, use Groq to summarize the session."""
    groq_key, _ = get_groq_key(cfg)
    if not groq_key:
        return

    history_dir = _gemini_history_dir()
    if not history_dir:
        return

    try:
        files = sorted(
            [os.path.join(history_dir, f) for f in os.listdir(history_dir)
             if os.path.isfile(os.path.join(history_dir, f))],
            key=os.path.getmtime,
            reverse=True,
        )
    except OSError:
        return

    if not files:
        return

    try:
        with open(files[0]) as f:
            history = f.read()
    except (IOError, UnicodeDecodeError):
        return

    if len(history) < 100:
        return

    if len(history) > 4000:
        # Truncate at a line boundary
        truncated = history[-4000:]
        newline = truncated.find("\n")
        if newline > 0:
            truncated = truncated[newline + 1:]
        history = "...\n" + truncated

    print("  Saving session summary for next time...")
    result, code = groq_call(groq_key, [{
        "role": "user",
        "content": (
            "Summarize this conversation in 2-3 sentences. Focus on what "
            "was worked on and any decisions made:\n\n%s" % history
        ),
    }])

    if code == 0 and result:
        save_summary(result)
        print("  Saved.")
    else:
        print("  (couldn't summarize — no Groq response)")


# ═════════════════════════════════════════════════════════════════════════════
#  LAUNCH GEMINI CLI (cross-platform)
# ═════════════════════════════════════════════════════════════════════════════

def launch_gemini(api_key, extra_args):
    """Launch the real Gemini CLI. Works on Mac/Linux/Windows."""
    if not check_gemini_cli():
        print("  Gemini CLI not found!")
        print("  Install it: npm install -g @google/gemini-cli")
        return 127

    env = os.environ.copy()
    env["GEMINI_API_KEY"] = api_key

    if os.name == "nt":
        try:
            result = subprocess.run(["gemini"] + extra_args, env=env)
            return result.returncode
        except OSError:
            print("  Failed to launch Gemini CLI.")
            return 127
    else:
        pid = os.fork()
        if pid == 0:
            try:
                os.execvpe("gemini", ["gemini"] + extra_args, env)
            except OSError:
                pass
            sys.exit(127)
        else:
            _, status = os.waitpid(pid, 0)
            return os.WEXITSTATUS(status) if os.WIFEXITED(status) else 1


