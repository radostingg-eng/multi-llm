#!/usr/bin/env python3
"""
multi-llm — Pool multiple free-tier API keys for seamless terminal chat.
Supports Gemini and Groq keys. Auto-rotates on rate limit.
"""

import base64
import getpass
import hashlib
import json
import os
import subprocess
import sys
import time
import urllib.request
import urllib.error

# ─── platform ────────────────────────────────────────────────────────────────
IS_WINDOWS = os.name == "nt"
if IS_WINDOWS:
    PROMPT = "> "
    COLOR_AI = ""
    COLOR_SYSTEM = ""
    COLOR_RESET = ""
else:
    PROMPT = "\033[1;32m> \033[0m"
    COLOR_AI = "\033[1;36m"      # cyan for AI responses
    COLOR_SYSTEM = "\033[1;33m"  # yellow for system messages
    COLOR_RESET = "\033[0m"

# ─── paths ───────────────────────────────────────────────────────────────────
CONFIG_DIR = os.path.expanduser("~/.multi-llm")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")
COOLDOWN_SECS = 3600  # 1h cooldown after rate limit

# ─── API endpoints ───────────────────────────────────────────────────────────
GEMINI_URL = "https://generativelanguage.googleapis.com/v1beta/models/%s:streamGenerateContent?alt=sse&key=%s"
GEMINI_MODEL = "gemini-2.5-flash"
GROQ_URL = "https://api.groq.com/openai/v1/chat/completions"
GROQ_MODEL = "llama-3.3-70b-versatile"


# ═════════════════════════════════════════════════════════════════════════════
#  KEY ENCRYPTION (simple passphrase-based obfuscation)
# ═════════════════════════════════════════════════════════════════════════════

def _derive_key(passphrase):
    """Derive a 32-byte key from passphrase using PBKDF2."""
    return hashlib.pbkdf2_hmac("sha256", passphrase.encode(), b"multi-llm-salt", 100000)

def _xor_bytes(data, key):
    """XOR data with repeating key."""
    return bytes(b ^ key[i % len(key)] for i, b in enumerate(data))

def encrypt_key(api_key, passphrase):
    """Encrypt an API key with a passphrase."""
    derived = _derive_key(passphrase)
    encrypted = _xor_bytes(api_key.encode(), derived)
    return base64.b64encode(encrypted).decode()

def decrypt_key(encrypted, passphrase):
    """Decrypt an API key with a passphrase."""
    derived = _derive_key(passphrase)
    data = base64.b64decode(encrypted)
    return _xor_bytes(data, derived).decode()


# ═════════════════════════════════════════════════════════════════════════════
#  CONFIG
# ═════════════════════════════════════════════════════════════════════════════

def load_config():
    if not os.path.exists(CONFIG_FILE):
        return None
    with open(CONFIG_FILE) as f:
        return json.load(f)

def save_config(cfg):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)
    if os.name != "nt":
        os.chmod(CONFIG_FILE, 0o600)


# ═════════════════════════════════════════════════════════════════════════════
#  SETUP
# ═════════════════════════════════════════════════════════════════════════════

def setup():
    print()
    print("  ╔═══════════════════════════════════════════╗")
    print("  ║       multi-llm — First-Time Setup        ║")
    print("  ╚═══════════════════════════════════════════╝")
    print()
    print("  Welcome! This tool lets you chat with AI using multiple")
    print("  free API keys. When one key runs out of free requests,")
    print("  it automatically switches to the next one.")
    print()
    print("  You'll need at least one API key to get started.")
    print("  Both are free — you just need to sign up:")
    print()
    print("    Gemini (Google):  https://aistudio.google.com/apikey")
    print("      1. Click 'Create API Key'")
    print("      2. Copy the key (starts with 'AIza...')")
    print()
    print("    Groq:             https://console.groq.com/keys")
    print("      1. Sign up / log in")
    print("      2. Click 'Create API Key'")
    print("      3. Copy the key (starts with 'gsk_...')")
    print()
    print("  Tip: Create keys with multiple accounts for more free usage!")
    print()
    print("  ── Step 1: Choose a passphrase (optional) ──")
    print("  This encrypts your keys on disk for extra security.")
    print("  Press Enter to skip — your keys will still be protected")
    print("  by file permissions (only you can read them).")
    print()

    passphrase = getpass.getpass("  Choose a passphrase (or press Enter to skip): ")
    if passphrase:
        confirm = getpass.getpass("  Confirm passphrase: ")
        if passphrase != confirm:
            print("  Passphrases don't match. Run 'multi-llm' to try again.")
            sys.exit(1)

    # Store a check value so we can verify passphrase on login
    check_value = encrypt_key("multi-llm-check", passphrase)

    cfg = {"keys": [], "cooldowns": {}, "check": check_value}

    print()
    print("  ── Step 2: Add your API keys ──")

    # Auto-detect keys from environment
    imported = _import_env_keys(cfg, passphrase)
    if imported:
        print()
        print("  Auto-detected %d key(s) from your environment:" % imported)
        for i, entry in enumerate(cfg["keys"]):
            print("    %d. %s" % (i + 1, entry["provider"]))
        print()
        add_more = input("  Add more keys manually? (y/n): ").strip().lower()
        if add_more == "y":
            print()
            _add_keys_interactive(cfg, passphrase)
    else:
        print()
        _add_keys_interactive(cfg, passphrase)

    if not cfg["keys"]:
        print()
        print("  No keys added. You need at least one key to use multi-llm.")
        print("  Run './multi-llm' again after getting a key from one of the links above.")
        sys.exit(1)

    save_config(cfg)
    print()
    print("  ── Setup complete! ──")
    protected = "encrypted" if passphrase else "file-protected"
    print("  Saved %d key(s) to ~/.multi-llm/config.json (%s)" % (len(cfg["keys"]), protected))
    print()
    print("  You're ready to go! Starting chat...")
    print()
    return cfg, passphrase


def _import_env_keys(cfg, passphrase):
    """Auto-detect API keys from environment variables."""
    count = 0
    # Scan GEMINI_API_KEY, GEMINI_API_KEY_2, GEMINI_API_KEY_3, ...
    for var in sorted(os.environ.keys()):
        if var.startswith("GEMINI_API_KEY"):
            val = os.environ[var].strip()
            if val:
                cfg["keys"].append({
                    "provider": "gemini",
                    "encrypted": encrypt_key(val, passphrase),
                })
                count += 1
    # Scan GROQ_API_KEY, GROQ_API_KEY_2, ...
    for var in sorted(os.environ.keys()):
        if var.startswith("GROQ_API_KEY"):
            val = os.environ[var].strip()
            if val:
                cfg["keys"].append({
                    "provider": "groq",
                    "encrypted": encrypt_key(val, passphrase),
                })
                count += 1
    return count


def _add_keys_interactive(cfg, passphrase):
    print("  Paste your keys one at a time. The input is hidden for security.")
    print("  Press Enter with no key when you're done.")
    print()
    while True:
        print("  What type of key?  [1] Gemini   [2] Groq   [enter] Done adding")
        choice = input("  > ").strip().lower()

        if choice in ("", "q", "quit", "done"):
            if not cfg["keys"]:
                print("  (No keys added yet — add at least one to continue)")
                again = input("  Try again? (y/n): ").strip().lower()
                if again == "y":
                    continue
            break
        elif choice == "1":
            provider = "gemini"
            hint = "starts with 'AIza...'"
        elif choice == "2":
            provider = "groq"
            hint = "starts with 'gsk_...'"
        else:
            print("  Type 1, 2, or press Enter to finish.")
            continue

        key = getpass.getpass("  Paste your %s key (%s): " % (provider, hint))
        if not key.strip():
            print("  Empty key — skipped.")
            continue

        # Basic format validation
        key = key.strip()
        if provider == "gemini" and not key.startswith("AIza"):
            print("  Warning: Gemini keys usually start with 'AIza'. Adding anyway.")
        if provider == "groq" and not key.startswith("gsk_"):
            print("  Warning: Groq keys usually start with 'gsk_'. Adding anyway.")

        cfg["keys"].append({
            "provider": provider,
            "encrypted": encrypt_key(key, passphrase),
        })
        count = sum(1 for k in cfg["keys"] if k["provider"] == provider)
        print("  Added %s key #%d" % (provider, count))
        print()


def unlock(cfg):
    """Ask for passphrase and verify it. Skips prompt if no passphrase was set."""
    # Try empty passphrase first (user skipped during setup)
    try:
        check = decrypt_key(cfg["check"], "")
        if check == "multi-llm-check":
            return ""
    except Exception:
        pass

    # Has a passphrase — ask for it
    passphrase = getpass.getpass("  Passphrase: ")
    try:
        check = decrypt_key(cfg["check"], passphrase)
        if check != "multi-llm-check":
            raise ValueError()
    except Exception:
        print("  Wrong passphrase.")
        sys.exit(1)
    return passphrase


# ═════════════════════════════════════════════════════════════════════════════
#  COOLDOWNS
# ═════════════════════════════════════════════════════════════════════════════

def is_available(cfg, idx):
    cooldowns = cfg.get("cooldowns", {})
    ts = cooldowns.get(str(idx), 0)
    return time.time() - ts > COOLDOWN_SECS

def mark_limited(cfg, idx):
    cfg.setdefault("cooldowns", {})[str(idx)] = time.time()
    save_config(cfg)

def status_line(cfg):
    gemini_total = sum(1 for k in cfg["keys"] if k["provider"] == "gemini")
    groq_total = sum(1 for k in cfg["keys"] if k["provider"] == "groq")
    gemini_up = sum(1 for i, k in enumerate(cfg["keys"]) if k["provider"] == "gemini" and is_available(cfg, i))
    groq_up = sum(1 for i, k in enumerate(cfg["keys"]) if k["provider"] == "groq" and is_available(cfg, i))
    return "Gemini: %d/%d  Groq: %d/%d" % (gemini_up, gemini_total, groq_up, groq_total)


# ═════════════════════════════════════════════════════════════════════════════
#  CHAT — GEMINI API (streaming)
# ═════════════════════════════════════════════════════════════════════════════

def gemini_stream(api_key, messages):
    """Send messages to Gemini and stream the response. Returns (text, error_code)."""
    # Convert messages to Gemini format
    contents = []
    for m in messages:
        role = "user" if m["role"] == "user" else "model"
        contents.append({"role": role, "parts": [{"text": m["content"]}]})

    payload = json.dumps({"contents": contents}).encode()
    url = GEMINI_URL % (GEMINI_MODEL, api_key)

    req = urllib.request.Request(url, data=payload, headers={
        "Content-Type": "application/json",
        "User-Agent": "multi-llm/1.0",
    })

    try:
        resp = urllib.request.urlopen(req)
    except urllib.error.HTTPError as e:
        if e.code == 429:
            return None, 429
        body = e.read().decode()[:200]
        print("  API error (%d): %s" % (e.code, body))
        return None, e.code
    except urllib.error.URLError as e:
        print("  Network error: %s" % e)
        return None, -1

    # Stream SSE response
    full_text = []
    print(COLOR_AI, end="", flush=True)
    for line in resp:
        line = line.decode().strip()
        if not line.startswith("data: "):
            continue
        data = line[6:]
        if data == "[DONE]":
            break
        try:
            chunk = json.loads(data)
            parts = chunk.get("candidates", [{}])[0].get("content", {}).get("parts", [])
            for part in parts:
                text = part.get("text", "")
                if text:
                    print(text, end="", flush=True)
                    full_text.append(text)
        except (json.JSONDecodeError, KeyError, IndexError):
            continue

    print(COLOR_RESET)
    return "".join(full_text), 0


# ═════════════════════════════════════════════════════════════════════════════
#  CHAT — GROQ API (streaming)
# ═════════════════════════════════════════════════════════════════════════════

def groq_stream(api_key, messages):
    """Send messages to Groq and stream the response. Returns (text, error_code)."""
    payload = json.dumps({
        "model": GROQ_MODEL,
        "messages": messages,
        "stream": True,
    }).encode()

    req = urllib.request.Request(GROQ_URL, data=payload, headers={
        "Authorization": "Bearer %s" % api_key,
        "Content-Type": "application/json",
        "User-Agent": "multi-llm/1.0",
    })

    try:
        resp = urllib.request.urlopen(req)
    except urllib.error.HTTPError as e:
        if e.code == 429:
            return None, 429
        body = e.read().decode()[:200]
        print("  API error (%d): %s" % (e.code, body))
        return None, e.code
    except urllib.error.URLError as e:
        print("  Network error: %s" % e)
        return None, -1

    full_text = []
    print(COLOR_AI, end="", flush=True)
    for line in resp:
        line = line.decode().strip()
        if not line.startswith("data: "):
            continue
        data = line[6:]
        if data == "[DONE]":
            break
        try:
            chunk = json.loads(data)
            content = chunk["choices"][0].get("delta", {}).get("content", "")
            if content:
                print(content, end="", flush=True)
                full_text.append(content)
        except (json.JSONDecodeError, KeyError, IndexError):
            continue

    print(COLOR_RESET)
    return "".join(full_text), 0


# ═════════════════════════════════════════════════════════════════════════════
#  SEND — tries keys in order, rotates on rate limit
# ═════════════════════════════════════════════════════════════════════════════

def send_message(cfg, passphrase, messages):
    """Try each available key until one works. Returns assistant text or None."""
    for i, entry in enumerate(cfg["keys"]):
        if not is_available(cfg, i):
            continue

        api_key = decrypt_key(entry["encrypted"], passphrase)

        if entry["provider"] == "gemini":
            text, code = gemini_stream(api_key, messages)
        else:
            text, code = groq_stream(api_key, messages)

        if code == 0 and text:
            return text
        elif code == 429:
            mark_limited(cfg, i)
            provider = entry["provider"]
            remaining = sum(
                1 for j, k in enumerate(cfg["keys"])
                if is_available(cfg, j) and j != i
            )
            print("%s  [rate limited — %s key #%d, %d keys left]%s" % (
                COLOR_SYSTEM,
                provider,
                sum(1 for k in cfg["keys"][:i+1] if k["provider"] == provider),
                remaining,
                COLOR_RESET,
            ))
            continue
        else:
            # Other error — skip this key but don't cooldown
            continue

    print()
    print("  All keys exhausted! Wait for cooldowns or add more keys.")
    print("  Run: multi-llm --add")
    return None


# ═════════════════════════════════════════════════════════════════════════════
#  MAIN
# ═════════════════════════════════════════════════════════════════════════════

def self_update():
    """Pull latest changes from the remote repo."""
    script_dir = os.path.dirname(os.path.abspath(__file__))
    print("  Updating multi-llm...")
    ret = subprocess.call(["git", "pull", "origin", "main"], cwd=script_dir)
    if ret == 0:
        print("  Up to date!")
        # Re-install hooks in case they changed
        setup_sh = os.path.join(script_dir, "setup.sh")
        if os.path.exists(setup_sh):
            subprocess.call(["bash", setup_sh], cwd=script_dir)
    else:
        print("  Update failed. Check your internet connection.")


def print_help():
    print("""
  multi-llm — Pool free API keys for seamless terminal chat

  Usage:
    multi-llm              Start chatting
    multi-llm --status     Show which keys are available
    multi-llm --add        Add more keys
    multi-llm --update     Pull latest version from GitHub
    multi-llm --reset      Clear all rate-limit cooldowns
    multi-llm --help       This message

  First run:
    Just run 'multi-llm' — it walks you through setup.

  Get free keys:
    Gemini: https://aistudio.google.com/apikey
    Groq:   https://console.groq.com/keys
""")


def main():
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print_help()
        return

    if "--update" in args:
        self_update()
        return

    cfg = load_config()

    if "--reset" in args:
        if cfg:
            cfg["cooldowns"] = {}
            save_config(cfg)
            print("  Cooldowns cleared.")
        return

    if "--status" in args:
        if cfg:
            print("  " + status_line(cfg))
        else:
            print("  Not set up yet. Run 'multi-llm' first.")
        return

    if "--add" in args:
        if not cfg:
            print("  Not set up yet. Run 'multi-llm' first.")
            return
        passphrase = unlock(cfg)
        _add_keys_interactive(cfg, passphrase)
        save_config(cfg)
        return

    # ── First-time setup ──
    if cfg is None:
        cfg, passphrase = setup()
    else:
        passphrase = unlock(cfg)

    # ── Chat loop ──
    print()
    print("  ╔═══════════════════════════════════════════╗")
    print("  ║              multi-llm chat               ║")
    print("  ╚═══════════════════════════════════════════╝")
    print("  %s" % status_line(cfg))
    print()
    print("  Commands:  /status  /help  quit")
    print()

    messages = []

    while True:
        try:
            user_input = input(PROMPT)
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if user_input.strip().lower() in ("quit", "exit", "/quit", "/exit"):
            break

        if user_input.strip().lower() == "/status":
            cfg = load_config()  # reload in case cooldowns changed
            print("  " + status_line(cfg))
            continue

        if user_input.strip().lower() in ("/", "/help"):
            print("  Commands:")
            print("    /status   Show how many keys are available")
            print("    /help     This message")
            print("    quit      Exit the chat")
            print()
            print("  How it works:")
            print("    Your message is sent to the first available API key.")
            print("    If that key is rate-limited, it automatically tries the next.")
            print("    Gemini keys are tried first, then Groq as fallback.")
            continue

        if not user_input.strip():
            continue

        messages.append({"role": "user", "content": user_input})
        print()

        text = send_message(cfg, passphrase, messages)
        if text:
            messages.append({"role": "assistant", "content": text})
        else:
            messages.pop()  # remove failed user message

        print()


if __name__ == "__main__":
    main()
