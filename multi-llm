#!/usr/bin/env python3
"""
multi-llm — Rotate API keys and launch native CLIs.
Thin wrapper: swaps keys, runs the real gemini/groq CLI. That's it.
"""

import json
import os
import subprocess
import sys
import time

# ─── paths ───────────────────────────────────────────────────────────────────
CONFIG_DIR = os.path.expanduser("~/.multi-llm")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")
COOLDOWN_SECS = 3600  # 1h cooldown after rate limit


# ═════════════════════════════════════════════════════════════════════════════
#  CONFIG
# ═════════════════════════════════════════════════════════════════════════════

def load_config():
    if not os.path.exists(CONFIG_FILE):
        return None
    with open(CONFIG_FILE) as f:
        return json.load(f)


def save_config(cfg):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)
    if os.name != "nt":
        os.chmod(CONFIG_FILE, 0o600)


# ═════════════════════════════════════════════════════════════════════════════
#  SETUP
# ═════════════════════════════════════════════════════════════════════════════

def setup():
    print()
    print("  multi-llm — First-Time Setup")
    print("  ─────────────────────────────")
    print()
    print("  This tool rotates your free API keys and launches")
    print("  the real Gemini CLI (or Groq CLI). When one key")
    print("  runs out, exit and re-run — it picks the next key.")
    print()
    print("  You need at least one API key. Both are free:")
    print()
    print("    Gemini:  https://aistudio.google.com/apikey")
    print("      -> Click 'Create API Key' -> copy it (starts with AIza...)")
    print()
    print("    Groq:    https://console.groq.com/keys")
    print("      -> Sign up -> 'Create API Key' -> copy it (starts with gsk_...)")
    print()
    print("  Tip: Use multiple Google/Groq accounts for more free usage!")
    print()

    cfg = {"gemini_keys": [], "groq_keys": [], "cooldowns": {}}

    # Auto-detect from environment
    env_count = 0
    for var in sorted(os.environ.keys()):
        if var.startswith("GEMINI_API_KEY"):
            val = os.environ[var].strip()
            if val:
                cfg["gemini_keys"].append(val)
                env_count += 1
    for var in sorted(os.environ.keys()):
        if var.startswith("GROQ_API_KEY"):
            val = os.environ[var].strip()
            if val:
                cfg["groq_keys"].append(val)
                env_count += 1

    if env_count:
        print("  Found %d key(s) in your environment:" % env_count)
        print("    %d Gemini, %d Groq" % (len(cfg["gemini_keys"]), len(cfg["groq_keys"])))
        print()
        add_more = input("  Add more keys manually? (y/n): ").strip().lower()
    else:
        add_more = "y"

    if add_more == "y":
        _add_keys_interactive(cfg)

    total = len(cfg["gemini_keys"]) + len(cfg["groq_keys"])
    if total == 0:
        print("  No keys added. Run 'multi-llm' again after getting a key.")
        sys.exit(1)

    save_config(cfg)
    print()
    print("  Saved %d key(s). You're ready — launching now..." % total)
    print()
    return cfg


def _add_keys_interactive(cfg):
    print()
    print("  Paste keys one at a time. Press Enter when done.")
    print()
    while True:
        print("  [1] Add Gemini key   [2] Add Groq key   [enter] Done")
        choice = input("  > ").strip()

        if choice == "":
            if not cfg["gemini_keys"] and not cfg["groq_keys"]:
                print("  You need at least one key!")
                continue
            break
        elif choice == "1":
            key = input("  Gemini key (AIza...): ").strip()
            if key:
                cfg["gemini_keys"].append(key)
                print("  Added Gemini key #%d" % len(cfg["gemini_keys"]))
        elif choice == "2":
            key = input("  Groq key (gsk_...): ").strip()
            if key:
                cfg["groq_keys"].append(key)
                print("  Added Groq key #%d" % len(cfg["groq_keys"]))
        else:
            print("  Type 1, 2, or press Enter.")
        print()


# ═════════════════════════════════════════════════════════════════════════════
#  COOLDOWNS
# ═════════════════════════════════════════════════════════════════════════════

def is_available(cfg, provider, idx):
    key = "%s:%d" % (provider, idx)
    ts = cfg.get("cooldowns", {}).get(key, 0)
    return time.time() - ts > COOLDOWN_SECS


def mark_limited(cfg, provider, idx):
    key = "%s:%d" % (provider, idx)
    cfg.setdefault("cooldowns", {})[key] = time.time()
    save_config(cfg)


def status_line(cfg):
    g_total = len(cfg.get("gemini_keys", []))
    g_up = sum(1 for i in range(g_total) if is_available(cfg, "gemini", i))
    q_total = len(cfg.get("groq_keys", []))
    q_up = sum(1 for i in range(q_total) if is_available(cfg, "groq", i))
    return "Gemini: %d/%d ready  Groq: %d/%d ready" % (g_up, g_total, q_up, q_total)


# ═════════════════════════════════════════════════════════════════════════════
#  LAUNCH NATIVE CLI
# ═════════════════════════════════════════════════════════════════════════════

def launch_gemini(api_key, extra_args):
    """Launch the real Gemini CLI with this API key. Returns exit code."""
    env = os.environ.copy()
    env["GEMINI_API_KEY"] = api_key
    # Use fork+exec so gemini fully owns the terminal
    pid = os.fork()
    if pid == 0:
        os.execvpe("gemini", ["gemini"] + extra_args, env)
        sys.exit(127)
    else:
        _, status = os.waitpid(pid, 0)
        return os.WEXITSTATUS(status) if os.WIFEXITED(status) else 1


def launch_groq(api_key, extra_args):
    """Launch the real Groq CLI with this API key. Returns exit code."""
    env = os.environ.copy()
    env["GROQ_API_KEY"] = api_key
    # Try groq CLI if installed
    groq_cmd = "groq"
    pid = os.fork()
    if pid == 0:
        os.execvpe(groq_cmd, [groq_cmd] + extra_args, env)
        sys.exit(127)
    else:
        _, status = os.waitpid(pid, 0)
        return os.WEXITSTATUS(status) if os.WIFEXITED(status) else 1


# ═════════════════════════════════════════════════════════════════════════════
#  SELF-UPDATE
# ═════════════════════════════════════════════════════════════════════════════

def self_update():
    script_dir = os.path.dirname(os.path.abspath(__file__))
    print("  Updating multi-llm...")
    ret = subprocess.call(["git", "pull", "origin", "main"], cwd=script_dir)
    if ret == 0:
        print("  Up to date!")
        setup_sh = os.path.join(script_dir, "setup.sh")
        if os.path.exists(setup_sh):
            subprocess.call(["bash", setup_sh], cwd=script_dir)
    else:
        print("  Update failed. Check your internet connection.")


# ═════════════════════════════════════════════════════════════════════════════
#  MAIN
# ═════════════════════════════════════════════════════════════════════════════

def print_help():
    print("""
  multi-llm — Rotate free API keys, launch native CLI

  Usage:
    multi-llm              Launch Gemini CLI with next available key
    multi-llm --status     Show which keys are available
    multi-llm --add        Add more keys
    multi-llm --update     Pull latest version from GitHub
    multi-llm --reset      Clear all rate-limit cooldowns
    multi-llm --help       This message

  Any other flags are passed straight to the Gemini/Groq CLI.
  Example: multi-llm -p "explain this code"

  When you hit a rate limit, just exit and re-run multi-llm.
  It automatically picks the next available key.
""")


def main():
    extra_args = []
    action = None

    args = sys.argv[1:]
    i = 0
    while i < len(args):
        if args[i] in ("--help", "-h"):
            action = "help"
        elif args[i] == "--status":
            action = "status"
        elif args[i] == "--add":
            action = "add"
        elif args[i] == "--update":
            action = "update"
        elif args[i] == "--reset":
            action = "reset"
        else:
            extra_args = args[i:]
            break
        i += 1

    if action == "help":
        print_help()
        return

    if action == "update":
        self_update()
        return

    cfg = load_config()

    if action == "reset":
        if cfg:
            cfg["cooldowns"] = {}
            save_config(cfg)
            print("  Cooldowns cleared.")
        return

    if action == "status":
        if cfg:
            print("  " + status_line(cfg))
        else:
            print("  Not set up yet. Run 'multi-llm' first.")
        return

    if action == "add":
        if not cfg:
            print("  Not set up yet. Run 'multi-llm' first.")
            return
        _add_keys_interactive(cfg)
        save_config(cfg)
        return

    # ── First-time setup ──
    if cfg is None:
        cfg = setup()

    # ── Pick best key and launch ──
    print("  " + status_line(cfg))

    # Try Gemini keys first
    for i, key in enumerate(cfg.get("gemini_keys", [])):
        if not is_available(cfg, "gemini", i):
            continue

        print("  Launching Gemini CLI (key #%d)..." % (i + 1))
        print()
        exit_code = launch_gemini(key, extra_args)

        if exit_code == 0:
            return  # clean exit
        else:
            print()
            print("  Gemini exited (code %d)." % exit_code)
            answer = input("  Rate limited? Mark this key and try next? (y/n): ").strip().lower()
            if answer == "y":
                mark_limited(cfg, "gemini", i)
                print("  Key #%d on cooldown for 1h. Trying next..." % (i + 1))
                continue
            return

    # Try Groq keys
    for i, key in enumerate(cfg.get("groq_keys", [])):
        if not is_available(cfg, "groq", i):
            continue

        print("  Launching Groq CLI (key #%d)..." % (i + 1))
        print()
        exit_code = launch_groq(key, extra_args)

        if exit_code == 0:
            return
        elif exit_code == 127:
            print("  Groq CLI not installed. Install it or add more Gemini keys.")
            return
        else:
            print()
            print("  Groq exited (code %d)." % exit_code)
            answer = input("  Rate limited? Mark this key and try next? (y/n): ").strip().lower()
            if answer == "y":
                mark_limited(cfg, "groq", i)
                continue
            return

    # All exhausted
    print()
    print("  All keys are on cooldown! Add more or wait.")
    print("  Run: multi-llm --add")


if __name__ == "__main__":
    main()
