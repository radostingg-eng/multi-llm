#!/usr/bin/env python3
"""
multi-llm — Rotate Gemini API keys and launch the native Gemini CLI.
When one key hits its rate limit, exit and re-run — it picks the next key.
"""

import json
import os
import subprocess
import sys
import time

# ─── paths ───────────────────────────────────────────────────────────────────
CONFIG_DIR = os.path.expanduser("~/.multi-llm")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")
COOLDOWN_SECS = 3600  # 1h cooldown after rate limit


# ═════════════════════════════════════════════════════════════════════════════
#  CONFIG
# ═════════════════════════════════════════════════════════════════════════════

def load_config():
    if not os.path.exists(CONFIG_FILE):
        return None
    with open(CONFIG_FILE) as f:
        return json.load(f)


def save_config(cfg):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)
    if os.name != "nt":
        os.chmod(CONFIG_FILE, 0o600)


# ═════════════════════════════════════════════════════════════════════════════
#  SETUP (runs once)
# ═════════════════════════════════════════════════════════════════════════════

def setup():
    print()
    print("  multi-llm — First-Time Setup")
    print()
    print("  This tool rotates your free Gemini API keys and")
    print("  launches the real Gemini CLI. When one key runs out,")
    print("  exit and re-run — it picks the next key automatically.")
    print()

    cfg = {"keys": [], "cooldowns": {}}

    # Auto-detect from environment
    for var in sorted(os.environ.keys()):
        if var.startswith("GEMINI_API_KEY"):
            val = os.environ[var].strip()
            if val:
                cfg["keys"].append(val)

    if cfg["keys"]:
        print("  Found %d Gemini key(s) in your environment." % len(cfg["keys"]))
    else:
        print("  No keys found in environment.")
        print()
        print("  Get a free key: https://aistudio.google.com/apikey")
        print("    -> Click 'Create API Key' -> copy it (starts with AIza...)")
        print()
        _add_keys_interactive(cfg)

    if not cfg["keys"]:
        print("  No keys added. Get one at https://aistudio.google.com/apikey")
        sys.exit(1)

    save_config(cfg)
    print("  Saved %d key(s)." % len(cfg["keys"]))
    print()
    return cfg


def _add_keys_interactive(cfg):
    print("  Paste your Gemini API key(s). Press Enter when done.")
    print()
    while True:
        key = input("  Key (or Enter to finish): ").strip()
        if not key:
            break
        cfg["keys"].append(key)
        print("  Added key #%d" % len(cfg["keys"]))


# ═════════════════════════════════════════════════════════════════════════════
#  COOLDOWNS
# ═════════════════════════════════════════════════════════════════════════════

def is_available(cfg, idx):
    ts = cfg.get("cooldowns", {}).get(str(idx), 0)
    return time.time() - ts > COOLDOWN_SECS


def mark_limited(cfg, idx):
    cfg.setdefault("cooldowns", {})[str(idx)] = time.time()
    save_config(cfg)


def status_line(cfg):
    total = len(cfg.get("keys", []))
    up = sum(1 for i in range(total) if is_available(cfg, i))
    return "%d/%d keys ready" % (up, total)


# ═════════════════════════════════════════════════════════════════════════════
#  LAUNCH
# ═════════════════════════════════════════════════════════════════════════════

def launch_gemini(api_key, extra_args):
    """Launch the real Gemini CLI with this API key. Returns exit code."""
    env = os.environ.copy()
    env["GEMINI_API_KEY"] = api_key
    pid = os.fork()
    if pid == 0:
        os.execvpe("gemini", ["gemini"] + extra_args, env)
        sys.exit(127)
    else:
        _, status = os.waitpid(pid, 0)
        return os.WEXITSTATUS(status) if os.WIFEXITED(status) else 1


# ═════════════════════════════════════════════════════════════════════════════
#  MAIN
# ═════════════════════════════════════════════════════════════════════════════

def self_update():
    script_dir = os.path.dirname(os.path.abspath(__file__))
    print("  Updating multi-llm...")
    ret = subprocess.call(["git", "pull", "origin", "main"], cwd=script_dir)
    if ret == 0:
        print("  Up to date!")
    else:
        print("  Update failed.")


def main():
    args = sys.argv[1:]

    # Our flags
    if args and args[0] in ("--help", "-h"):
        print("""
  multi-llm — Rotate Gemini API keys, launch native CLI

  multi-llm              Launch Gemini CLI with next available key
  multi-llm --status     Show which keys are ready
  multi-llm --add        Add more keys
  multi-llm --update     Pull latest version
  multi-llm --reset      Clear all cooldowns

  Everything else passes to gemini:
    multi-llm -p "explain this"
    multi-llm --model gemini-2.5-pro
""")
        return

    if args and args[0] == "--update":
        self_update()
        return

    cfg = load_config()

    if args and args[0] == "--reset":
        if cfg:
            cfg["cooldowns"] = {}
            save_config(cfg)
            print("  Cooldowns cleared.")
        return

    if args and args[0] == "--status":
        print("  " + status_line(cfg) if cfg else "  Not set up. Run 'multi-llm'.")
        return

    if args and args[0] == "--add":
        if not cfg:
            cfg = {"keys": [], "cooldowns": {}}
        _add_keys_interactive(cfg)
        save_config(cfg)
        return

    # Pass everything else to gemini
    extra_args = args

    # First-time setup (only runs once)
    if cfg is None:
        cfg = setup()

    # Pick next available key and launch
    print("  %s" % status_line(cfg))

    for i, key in enumerate(cfg.get("keys", [])):
        if not is_available(cfg, i):
            continue

        print("  Using key #%d" % (i + 1))
        print()
        exit_code = launch_gemini(key, extra_args)

        if exit_code == 0:
            return

        print()
        answer = input("  Rate limited? Try next key? (y/n): ").strip().lower()
        if answer == "y":
            mark_limited(cfg, i)
            continue
        return

    print("  All keys on cooldown! Add more: multi-llm --add")


if __name__ == "__main__":
    main()
